# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/finance_news
DATABASE_SYNC_URL=postgresql://postgres:password@localhost:5432/finance_news

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (for embeddings, optional)
OPENAI_API_KEY=sk-...

# Embedding model: "openai" or "local"
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# News sources
RSS_FEEDS=https://feeds.reuters.com/reuters/businessNews,https://feeds.bloomberg.com/markets/news.rss

# SEC EDGAR
SEC_USER_AGENT=YourName yourname@email.com

# Alert thresholds
ALERT_IMPACT_THRESHOLD=0.7
ALERT_NOVELTY_THRESHOLD=0.6
